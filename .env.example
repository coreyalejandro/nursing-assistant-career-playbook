# OPENROUTER_API_KEY: required — the model layer runs on OpenRouter (one API,
# any model: OpenAI, Anthropic, Llama, etc.). Get a key at openrouter.ai/keys.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: which model to use (default: openai/gpt-4o-mini).
# Examples: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, meta-llama/llama-3.3-70b-instruct
# Live web search is added automatically (":online") for jobs/wages lookups.
OPENROUTER_MODEL="openai/gpt-4o-mini"

# --- Supabase (Auth + Postgres) -------------------------------------------
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY: required for sign-in + cross-device
# profile sync. Both are PUBLIC client values (safe in the browser bundle); their
# power is bounded by the Row-Level Security policies in supabase/migrations/.
# Find them in your Supabase project → Settings → API. Without them the app still
# runs in local-only mode (progress saved per-device via localStorage).
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# SUPABASE_SERVICE_ROLE_KEY: SERVER-ONLY secret (never exposed to the browser,
# no VITE_ prefix). Only needed by the enterprise audit store (SupabaseAuditStore)
# to write the append-only ledger. Leave blank for the free/consumer tier.
SUPABASE_SERVICE_ROLE_KEY=""

# ADZUNA_APP_ID / ADZUNA_APP_KEY: required for the live jobs API (#3).
# Free keys at developer.adzuna.com.
ADZUNA_APP_ID="MY_ADZUNA_APP_ID"
ADZUNA_APP_KEY="MY_ADZUNA_APP_KEY"

# APP_URL: the public URL where this app is hosted (used for self-referential
# links and as the OpenRouter HTTP-Referer attribution header).
APP_URL="MY_APP_URL"

# NODE_ENV: set to "production" in deployment so the server serves the built
# /dist assets instead of running the Vite dev middleware.
NODE_ENV="development"

# PORT: injected by the host (Render / Cloud Run / etc.); default 8080.
# PORT="8080"

# VITE_APP_TIER: product tier for feature flags — "free" (default), "pro", or
# "enterprise". See src/lib/tier.ts and ENTERPRISE.md. Read at build time.
VITE_APP_TIER="free"

# --- Freemium monetization (#1) -------------------------------------------
# VITE_UPGRADE_URL: a Stripe Payment Link for the $4.99/mo Pro plan (client,
# build-time). The upgrade modal appends ?client_reference_id=<user id>.
VITE_UPGRADE_URL=""
# STRIPE_WEBHOOK_SECRET: SERVER-ONLY. Set in Cloudflare so the webhook
# (functions/api/stripe-webhook.ts) can verify Stripe signatures and flip a
# user's profiles.plan to 'pro' on checkout. Requires SUPABASE_SERVICE_ROLE_KEY.
STRIPE_WEBHOOK_SECRET=""
# FREE_DAILY_AI_LIMIT: free-tier AI calls per day (default 10). Optional.
# FREE_DAILY_AI_LIMIT="10"
